# hola-eduardo — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# See tasks/env-unification-plan.md for the full naming convention reference.
# NEVER commit .env — only .env.example is tracked.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000          # Public base URL (auth redirects, webhooks)

# ── Database ──────────────────────────────────────────────────────────────────
# Dev DB runs on port 5438 to avoid conflicts when running multiple apps
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hola_eduardo

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid                  # client-side mirror — must match AUTH_MODE
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32  # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000  # must match APP_URL
# Clerk (required when AUTH_MODE=clerk or hybrid)
CLERK_SECRET_KEY=                      # sk_test_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_test_... from clerk.com → API Keys

# ── AI — Local Providers (development) ────────────────────────────────────────
VITE_AI_BASE_URL=http://localhost:11434/v1  # Ollama base URL (default dev AI)
AI_OLLAMA_MODEL=llama3.2              # run: ollama list
AI_LMSTUDIO_MODEL=llama3.2            # model identifier in LM Studio
OLLAMA_ORIGINS=*                      # CORS allowed origins for Ollama

# ── AI — Cloud Providers (production) ─────────────────────────────────────────
MINIMAX_API_KEY=                      # from platform.minimaxi.chat (primary LLM)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M1
OPENAI_API_KEY=                       # optional fallback
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=                    # optional fallback
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Default local admin (seeded by db:seed:admin) ────────────────────────────
# Run `pnpm db:seed:admin` after migrations to create the initial admin user.
# These same values live in the workspace-level .env so they stay consistent.
DEFAULT_ADMIN_EMAIL=edd_admin@local.com
DEFAULT_ADMIN_PASSWORD=Passw0rd!234

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                      # from sentry.io → Project → DSN (empty = disabled)
