# MiniMax (cloud LLM, OpenAI-compatible)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=abab6.5-chat

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tanstack_template

# Auth Configuration
AUTH_MODE=hybrid
VITE_AUTH_MODE=hybrid
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-with-a-long-random-secret
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI Configuration
VITE_AI_BASE_URL=http://localhost:11434/v1
AI_LMSTUDIO_MODEL=llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_ORIGINS=*
