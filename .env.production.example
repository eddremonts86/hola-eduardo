# hola-eduardo — Production Environment Configuration
# Copy this file to .env.production and fill in real values.
# See tasks/env-unification-plan.md for the full naming convention reference.
# NEVER commit .env.production — only .env.production.example is tracked.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://hola.eduardoinerarte.dk

# ── Database (matches docker-compose.prod.yml) ────────────────────────────────
POSTGRES_USER=hola
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hola_prod
DATABASE_URL=postgresql://hola:change_me_strong_password@db:5432/hola_prod

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid
BETTER_AUTH_SECRET=change_me_generate_with_openssl  # openssl rand -base64 32
BETTER_AUTH_URL=https://hola.eduardoinerarte.dk     # must match APP_URL
# Clerk (required when AUTH_MODE=clerk or hybrid)
CLERK_SECRET_KEY=                      # sk_live_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_live_... from clerk.com → API Keys

# ── AI — Cloud Providers ──────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here  # from platform.minimaxi.chat (primary LLM)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M1
OPENAI_API_KEY=                        # optional fallback
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=                     # optional fallback
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                       # from sentry.io → Project → DSN (empty = disabled)
